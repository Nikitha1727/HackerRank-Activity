#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>

int main() {
    char command[100];

    while (1) {
        printf("myshell> ");
        fgets(command, sizeof(command), stdin);

        if (fork() == 0) {
            system(command);
            exit(0);
        } else {
            wait(NULL);
        }
    }
    return 0;
}
