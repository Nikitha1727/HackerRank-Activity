#include <stdio.h>

int main() {
    int n;
    // Read input n from STDIN
    if (scanf("%d", &n) != 1) {
        return 0; // Exit if input is invalid
    }

    if (n > 0) {
        printf("<"); // Print the opening '<'

        long long current_term = 1;
        for (int i = 0; i < n; ++i) {
            if (i > 0) {
                printf(" "); // Print space separator before subsequent terms
            }
            printf("%lld", current_term); // Print the current term
            current_term *= 2; // Double the term for the next iteration
        }

        printf(">"); // Print the closing '>'
    }

    return 0;
}
