#include <stdio.h>
#include <string.h>

#define MAX 100

// Structure (FIELDS)
struct Contact {
    char name[50];
    char phone[15];
};

struct Contact contacts[MAX];
int count = 0;

// Add Contact
void addContact() {
    if (count >= MAX) {
        printf("Contact list full!\n");
        return;
    }

    printf("Enter name: ");
    scanf(" %[^\n]", contacts[count].name);

    printf("Enter phone: ");
    scanf("%s", contacts[count].phone);

    count++;
    printf("Contact added successfully!\n\n");
}

// View Contacts
void viewContacts() {
    if (count == 0) {
        printf("No contacts available.\n\n");
        return;
    }

    printf("\n--- Contact List ---\n");
    for (int i = 0; i < count; i++) {
        printf("%d. %s - %s\n", i + 1, contacts[i].name, contacts[i].phone);
    }
    printf("\n");
}

// Search Contact
void searchContact() {
    char searchName[50];
    int found = 0;

    printf("Enter name to search: ");
    scanf(" %[^\n]", searchName);

    for (int i = 0; i < count; i++) {
        if (strcmp(contacts[i].name, searchName) == 0) {
            printf("Found: %s - %s\n\n", contacts[i].name, contacts[i].phone);
            found = 1;
        }
    }

    if (!found) {
        printf("Contact not found.\n\n");
    }
}

// Delete Contact
void deleteContact() {
    char deleteName[50];
    int found = 0;

    printf("Enter name to delete: ");
    scanf(" %[^\n]", deleteName);

    for (int i = 0; i < count; i++) {
        if (strcmp(contacts[i].name, deleteName) == 0) {
            for (int j = i; j < count - 1; j++) {
                contacts[j] = contacts[j + 1];
            }
            count--;
            printf("Contact deleted successfully!\n\n");
            found = 1;
            break;
        }
    }

    if (!found) {
        printf("Contact not found.\n\n");
    }
}

// Main Menu
int main() {
    int choice;

    while (1) {
        printf("==== Contact Book ====\n");
        printf("1. Add Contact\n");
        printf("2. View Contacts\n");
        printf("3. Search Contact\n");
        printf("4. Delete Contact\n");
        printf("5. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: addContact(); break;
            case 2: viewContacts(); break;
            case 3: searchContact(); break;
            case 4: deleteContact(); break;
            case 5: return 0;
            default: printf("Invalid choice!\n\n");
        }
    }
}
